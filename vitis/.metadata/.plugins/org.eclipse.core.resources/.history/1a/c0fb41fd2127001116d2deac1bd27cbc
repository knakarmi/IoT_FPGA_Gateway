/* =============================================================================
 * IoT Gateway - Week 7
 * File   : interrupt_handler.c
 * Purpose: GIC (Generic Interrupt Controller) setup for:
 *   - AXI DMA MM2S done interrupt
 *   - AXI DMA S2MM done interrupt
 *   - Packet parser IRQ (from xlconcat_irq In2)
 * =============================================================================
 */

#include "interrupt_handler.h"
#include "dma_handler.h"
#include "xil_printf.h"
#include "xil_exception.h"

/* GIC instance */
static XScuGic gic_inst;

/* Parser IRQ counter */
volatile int g_parser_irq_count = 0;

/* ---------------------------------------------------------------------------
 * parser_isr
 * Called when packet parser detects a dropped or classified packet
 * --------------------------------------------------------------------------- */
void parser_isr(void *callback)
{
    g_parser_irq_count++;
    xil_printf("PARSER IRQ: packet event #%d\r\n", g_parser_irq_count);
    /* In a full implementation: read parser status registers via AXI-Lite
     * to get protocol_class, error_code, ip_src, ip_dst etc. */
}

/* ---------------------------------------------------------------------------
 * interrupt_init
 * Initialize the ARM GIC and connect all interrupt handlers
 * --------------------------------------------------------------------------- */
int interrupt_init(void)
{
    XScuGic_Config *gic_cfg;
    int status;

    /* Look up GIC configuration */
    gic_cfg = XScuGic_LookupConfig(XPAR_SCUGIC_SINGLE_DEVICE_ID);
    if (!gic_cfg) {
        xil_printf("GIC: LookupConfig failed\r\n");
        return XST_FAILURE;
    }

    /* Initialize GIC */
    status = XScuGic_CfgInitialize(&gic_inst, gic_cfg,
                                    gic_cfg->CpuBaseAddress);
    if (status != XST_SUCCESS) {
        xil_printf("GIC: CfgInitialize failed %d\r\n", status);
        return status;
    }

    /* ------------------------------------------------------------------
     * Connect DMA MM2S interrupt
     * ------------------------------------------------------------------ */
    status = XScuGic_Connect(&gic_inst, DMA_MM2S_IRQ_ID,
                              (Xil_InterruptHandler)dma_mm2s_isr,
                              NULL);
    if (status != XST_SUCCESS) {
        xil_printf("GIC: MM2S connect failed %d\r\n", status);
        return status;
    }
    XScuGic_SetPriorityTriggerType(&gic_inst, DMA_MM2S_IRQ_ID,
                                    DMA_IRQ_PRIORITY, IRQ_TRIGGER_RISING);
    XScuGic_Enable(&gic_inst, DMA_MM2S_IRQ_ID);

    /* ------------------------------------------------------------------
     * Connect DMA S2MM interrupt
     * ------------------------------------------------------------------ */
    status = XScuGic_Connect(&gic_inst, DMA_S2MM_IRQ_ID,
                              (Xil_InterruptHandler)dma_s2mm_isr,
                              NULL);
    if (status != XST_SUCCESS) {
        xil_printf("GIC: S2MM connect failed %d\r\n", status);
        return status;
    }
    XScuGic_SetPriorityTriggerType(&gic_inst, DMA_S2MM_IRQ_ID,
                                    DMA_IRQ_PRIORITY, IRQ_TRIGGER_RISING);
    XScuGic_Enable(&gic_inst, DMA_S2MM_IRQ_ID);

    /* ------------------------------------------------------------------
     * Connect parser IRQ
     * ------------------------------------------------------------------ */
#ifdef PARSER_IRQ_ID
    status = XScuGic_Connect(&gic_inst, PARSER_IRQ_ID,
                              (Xil_InterruptHandler)parser_isr,
                              NULL);
    if (status != XST_SUCCESS) {
        xil_printf("GIC: Parser IRQ connect failed %d (non-fatal)\r\n",
                   status);
        /* Non-fatal: parser IRQ is optional for basic operation */
    } else {
        XScuGic_SetPriorityTriggerType(&gic_inst, PARSER_IRQ_ID,
                                        PARSER_IRQ_PRIORITY,
                                        IRQ_TRIGGER_RISING);
        XScuGic_Enable(&gic_inst, PARSER_IRQ_ID);
    }
#endif

    /* ------------------------------------------------------------------
     * Connect GIC to ARM exception handler and enable interrupts
     * ------------------------------------------------------------------ */
    Xil_ExceptionRegisterHandler(XIL_EXCEPTION_ID_INT,
                                  (Xil_ExceptionHandler)XScuGic_InterruptHandler,
                                  &gic_inst);
    Xil_ExceptionEnable();

    xil_printf("GIC: MM2S IRQ=%d, S2MM IRQ=%d, Parser IRQ=%d\r\n",
               DMA_MM2S_IRQ_ID, DMA_S2MM_IRQ_ID, PARSER_IRQ_ID);

    return XST_SUCCESS;
}
