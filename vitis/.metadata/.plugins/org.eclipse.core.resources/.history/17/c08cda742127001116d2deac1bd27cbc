/* =============================================================================
 * IoT Gateway - Week 7
 * File   : aes_key_loader.c
 * Purpose: Load AES-256 key and IV into the PL encryption core
 *
 * The AES core (aes256gcm_0) has its key/IV ports connected to AXI GPIO
 * blocks in the block design:
 *   axi_gpio_key     : drives aes_gcm_key_word_i[255:0]  (8 x 32-bit words)
 *   axi_gpio_key_val : drives aes_gcm_key_word_val_i[3:0] (4-bit strobe)
 *   axi_gpio_iv      : drives aes_gcm_iv_i[95:0]          (3 x 32-bit words)
 *   axi_gpio_iv_val  : drives aes_gcm_iv_val_i             (1-bit strobe)
 *
 * Key loading sequence (from BLu85 core documentation):
 *   1. Write key word 0 (MSB) to GPIO channel
 *   2. Assert key_word_val with appropriate word index
 *   3. Repeat for all 8 words (256-bit = 8 x 32-bit)
 *   4. Write IV words (3 x 32-bit = 96-bit)
 *   5. Assert iv_val
 * =============================================================================
 */

#include "aes_key_loader.h"
#include "xil_printf.h"
#include "xil_io.h"
#include <string.h>

/* ---------------------------------------------------------------------------
 * AXI GPIO base addresses from xparameters.h
 * These are generated by Vitis from the .xsa file
 * Note: actual names depend on how GPIOs were named in block design
 * --------------------------------------------------------------------------- */
#ifndef XPAR_AXI_GPIO_KEY_BASEADDR
  /* Fallback: use the first GPIO found - update after checking xparameters.h */
  #define AES_GPIO_KEY_BASE     XPAR_AXI_GPIO_0_BASEADDR
#else
  #define AES_GPIO_KEY_BASE     XPAR_AXI_GPIO_KEY_BASEADDR
#endif

/* AXI GPIO register offsets */
#define GPIO_DATA_OFFSET    0x00    /* Data register (channel 1) */
#define GPIO_TRI_OFFSET     0x04    /* Tri-state (direction) register */
#define GPIO_DATA2_OFFSET   0x08    /* Data register (channel 2) */
#define GPIO_TRI2_OFFSET    0x0C    /* Tri-state register (channel 2) */

/* ---------------------------------------------------------------------------
 * gpio_write32
 * Write a 32-bit value to an AXI GPIO data register
 * --------------------------------------------------------------------------- */
static void gpio_write32(u32 base_addr, u32 value)
{
    Xil_Out32(base_addr + GPIO_DATA_OFFSET, value);
}

/* ---------------------------------------------------------------------------
 * aes_load_key
 * Load 256-bit AES key and 96-bit IV into the PL AES-256-GCM core
 *
 * Parameters:
 *   key - pointer to 32-byte (256-bit) AES key, big-endian
 *   iv  - pointer to 12-byte (96-bit) IV/nonce, big-endian
 * --------------------------------------------------------------------------- */
int aes_load_key(const u8 *key, const u8 *iv)
{
    int i;
    u32 word;

    xil_printf("AES: Loading 256-bit key...\r\n");

    /* ------------------------------------------------------------------
     * Load AES-256 key: 8 words x 32-bit = 256-bit
     * The BLu85 core expects key words loaded MSB first
     * key_word_val_i[3:0] = word index (0-7)
     * ------------------------------------------------------------------ */
    for (i = 0; i < 8; i++) {
        /* Pack 4 bytes into a 32-bit word (big-endian) */
        word = ((u32)key[i*4 + 0] << 24) |
               ((u32)key[i*4 + 1] << 16) |
               ((u32)key[i*4 + 2] <<  8) |
               ((u32)key[i*4 + 3]);

        /* Write key word to GPIO */
        gpio_write32(AES_GPIO_KEY_BASE, word);

        /* Assert key_word_val with word index
         * key_word_val_i[3:0] encodes which of the 8 words is being loaded */
        gpio_write32(AES_GPIO_KEY_BASE + GPIO_DATA2_OFFSET, (u32)i);

        /* Small delay to ensure PL sees the strobe */
        /* In production: use proper handshake via aes_gcm_ready_o */
        volatile int delay;
        for (delay = 0; delay < 100; delay++);

        /* De-assert strobe */
        gpio_write32(AES_GPIO_KEY_BASE + GPIO_DATA2_OFFSET, 0);

        xil_printf("AES: Key word %d = 0x%08X\r\n", i, word);
    }

    xil_printf("AES: Loading 96-bit IV...\r\n");

    /* ------------------------------------------------------------------
     * Load IV: 3 words x 32-bit = 96-bit
     * ------------------------------------------------------------------ */
    for (i = 0; i < 3; i++) {
        word = ((u32)iv[i*4 + 0] << 24) |
               ((u32)iv[i*4 + 1] << 16) |
               ((u32)iv[i*4 + 2] <<  8) |
               ((u32)iv[i*4 + 3]);

        gpio_write32(AES_GPIO_KEY_BASE + 0x10, word);  /* IV GPIO offset */

        volatile int delay;
        for (delay = 0; delay < 100; delay++);

        xil_printf("AES: IV word %d = 0x%08X\r\n", i, word);
    }

    /* Assert iv_val strobe */
    gpio_write32(AES_GPIO_KEY_BASE + 0x14, 1);
    volatile int delay;
    for (delay = 0; delay < 100; delay++);
    gpio_write32(AES_GPIO_KEY_BASE + 0x14, 0);

    xil_printf("AES: Key and IV loaded successfully\r\n");
    return XST_SUCCESS;
}

/* ---------------------------------------------------------------------------
 * aes_verify_ready
 * Check aes_gcm_ready_o signal (exposed as external port)
 * In current design this is an FPGA output pin - reads via GPIO
 * --------------------------------------------------------------------------- */
int aes_verify_ready(void)
{
    /* aes_gcm_ready_o is exposed as external port on the FPGA
     * In a future revision this should be read via AXI GPIO input */
    xil_printf("AES: Ready check - assumes core is ready after key load\r\n");
    return XST_SUCCESS;
}
